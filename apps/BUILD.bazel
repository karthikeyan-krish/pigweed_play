        "@pigweed//pw_thread:sleep",
        "@pigweed//pw_thread:thread_core",
        "@pigweed//pw_string",
        "@pigweed//pw_system:work_queue",
    ],
    copts = ["-mcpu=cortex-m4", "-mthumb"],
)

