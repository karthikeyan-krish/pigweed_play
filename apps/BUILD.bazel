################################################################################

cc_binary(
    name = "application",
    srcs = ["src/application/main.cc"],
    deps = [
        ":application_lib",
        ":startup",
        "//targets/stm32l4xx:linker_script",
    ],
    copts = ["-mcpu=cortex-m4", "-mthumb"],
)

cc_binary(
    name = "application_slot_a",
    srcs = ["src/application/main.cc"],
    deps = [
        ":application_lib",
        ":startup",
        "//targets/stm32l4xx:application_linker_script_a",
