load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@pigweed//pw_build:binary_tools.bzl", "pw_elf_to_bin")
load("//targets:transition.bzl", "stm32l4xx_cc_binary")
load("@hedron_compile_commands//:refresh_compile_commands.bzl", "refresh_compile_commands")
load("@pigweed//pw_build:pigweed.bzl", "pw_cc_test")
load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

exports_files([
    "openocd_stm32l4xx.cfg",
])

cc_library(
    name = "startup",
    srcs = ["startup/startup_stm32l475xx.s"],
    alwayslink = True,
)

################################################################################
# bootloader                                                                   #
################################################################################

cc_binary(
    name = "bootloader",
    srcs = [
        "startup/startup_stm32l475xx.s",
    ],
    deps = [
        ":bootloader_lib",
    ],
    copts = ["-mcpu=cortex-m4", "-mthumb"],
    linkopts = [
        "-T$(location //targets/stm32l4xx:bootloader_linker_script)",
    ],
    additional_linker_inputs = [
        "//targets/stm32l4xx:bootloader_linker_script",
    ],
)

cc_library(
    name = "bootloader_lib",
    alwayslink = True,
    srcs = glob(
    [
        "include/main.h",
        "src/bootloader/src/*.cc",
        "src/bootloader/src/*.c",
        "src/bsp/*.h",
        "src/bsp/*.c",
    ]),
    includes = [
        "include",
        "src/bootloader",
        "src/bootloader/include",
        "src/bsp",
    ],
    deps = [
        ":bootloader_core",
        ":bootloader_transport_uart_dma",
        ":bootloader_target",
        ":bootloader_storage",
        "@cmsis_device//:default_cmsis_init",
        "@stm32l4xx_hal_driver//:hal_driver",
        "@pigweed//pw_log",
        "@pigweed//pw_sys_io_stm32cube",
        "@pigweed//pw_assert:backend_impl",
        "@pigweed//pw_assert:check_backend_impl",
        "@pigweed//pw_assert:assert_backend_impl",
    ],
    copts = ["-mcpu=cortex-m4", "-mthumb"],
)

cc_library(
    name = "bootloader_core",
    srcs = [
        "src/bootloader/src/bld_crc32.c",
        "src/bootloader/src/bld_meta.c",
        "src/bootloader/src/bld_engine.c",
    ],
    hdrs = glob([
        "src/bootloader/include/*.h",
    ]),
    includes = [
        "src/bootloader/include",
        "src/bootloader",
    ],
    deps = ["@pigweed//pw_log",],
)

cc_library(
    name = "bootloader_transport_uart_dma",
    srcs = [
        "src/bootloader/src/bld_transport_uart_dma.c",
    ],
    hdrs = glob([
        "src/bootloader/include/*.h",
    ]),
    includes = [
        "src/bootloader/include",
        "src/bootloader",
    ],
)

cc_library(
    name = "bootloader_storage",
    srcs = [
        "src/bootloader/src/bld_storage_flash.c",
    ],
    hdrs = glob([
        "src/bootloader/include/*.h",
    ]),
    includes = [
        "src/bootloader/include",
        "src/bootloader",
    ],
)

cc_library(
    name = "bootloader_target",
    srcs = [
        "src/bootloader/src/bld_boot.c",
        "src/bootloader/src/stm32_hal_msp.c",
        "src/bootloader/src/stm32l4xx_it.c",
    ],
    hdrs = glob([
        "include/main.h",
        "src/bootloader/include/*.h",
        "src/bsp/*.h",
    ]),
    includes = [
        "include",
        "src/bsp",
        "src/bootloader/include",
        "src/bootloader",
    ],
    deps = [
        "@cmsis_device//:default_cmsis_init",
        "@stm32l4xx_hal_driver//:hal_driver",
    ],
)

stm32l4xx_cc_binary(
    name = "bootloader.elf",
    binary = ":bootloader",
    platform = "//targets/stm32l4xx:bootloader_platform",
)

pw_elf_to_bin(
    name = "bootloader_bin",
    bin_out = "bootloader.bin",
    elf_input = ":bootloader.elf",
)

