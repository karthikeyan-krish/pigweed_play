        ":application_lib",
        ":startup",
        "//targets/stm32l4xx:application_linker_script_b",
    ],
    copts = [
        "-mcpu=cortex-m4",
        "-mthumb",
        "-DBLD_APP_SLOT_BUILD=1"],
)

