        "src/application",
        "src/bsp",
    ],
    deps = [
        ":active_object_lib",
        ":state_machine_lib",
        ":bootloader_confirm_lib",
        "@cmsis_device//:default_cmsis_init", 
        "@stm32l4xx_hal_driver//:hal_driver",
        "@freertos",
