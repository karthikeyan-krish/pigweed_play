        "@pigweed//pw_containers:inline_queue",
    ],
)

cc_library(
    name = "state_machine_lib",
    hdrs = glob(["src/application/threads/state_machine.h",]),
    srcs = ["src/application/threads/state_machine.cc"],
    includes = ["src/application/threads"],
    deps = [
        "@pigweed//pw_function",
